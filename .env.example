# Пример переменных окружения. Скопируй в .env и заполни.
# НИКОГДА не коммить .env в git!

# Обязательно: токен от @BotFather
BOT_TOKEN=ВАШ_ТОКЕН_ОТ_BOTFATHER

# Публичный HTTPS, который отдаёт бэкенд (GET /). Совпадает с /newapp в BotFather.
MINI_APP_URL=https://dj-school.ВАШ-ДОМЕН.tld

# Backend URL (для бота, чтобы дёргать /api/grant)
BACKEND_URL=http://localhost:8000

# --- Опционально: платёжные провайдеры ---
# TON
TON_MERCHANT_WALLET=UQ...
# Prodamus
PRODAMUS_API_KEY=
PRODAMUS_SHOP_ID=
PRODAMUS_WEBHOOK_SECRET=
